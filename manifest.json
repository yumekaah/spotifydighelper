{
  "manifest_version": 2,
  "name": "Sxxxxfy Dig Helper",
  "version": "0.2.0",
  "description": "Sxxxxfy Web Player上の楽曲にDJ向けDig支援情報 (Beatport/Bandcamp/Traxsource/Discogs/iTunes リンク) を表示する。",
  "browser_specific_settings": {
    "gecko": {
      "id": "spotifydighelper@ymk",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "web_accessible_resources": ["favicons/*"],
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": [
        "constants.js",
        "utils.js",
        "spotify.js",
        "ui.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
